# ─────────────────────────────────────────────
#  PetStore Hub — Environment Variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string

# Database
# Development (SQLite):
DATABASE_URL=sqlite:///petstorehub.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/petstorehub

# JWT
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_TOKEN_EXPIRES=86400

# Cloudinary (optional — falls back to local uploads if not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Crypto Wallet Addresses
BITCOIN_WALLET=bc1qexamplebitcoinaddress
ETHEREUM_WALLET=0xExampleEthereumAddress
USDT_TRC20_WALLET=TExampleTronAddress
USDT_BEP20_WALLET=0xExampleBEP20Address
SOLANA_WALLET=ExampleSolanaAddress

# Admin Seed
ADMIN_EMAIL=admin@petstorehub.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Store Admin

# CORS
FRONTEND_URL=http://localhost:5173
